{
  "name": "template-repo-mobile-multi",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:prebuild": "expo prebuild --platform ios --non-interactive",
    "ios:build": "expo run:ios",
    "web": "expo start --web",
    "doctor": "npx expo-doctor",
    "postinstall": "tsx ./scripts/ensure-detox-jest-compat.ts",
    "test": "npm run test:unit",
    "test:unit": "jest --coverage --ci --passWithNoTests",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm test && npm run doctor",
    "android:prebuild": "expo prebuild --platform android --non-interactive",
    "kotlin:assembleDebug": "cd kotlin && ./gradlew assembleDebug",
    "kotlin:assembleRelease": "cd kotlin && ./gradlew assembleRelease",
    "kotlin:test": "cd kotlin && ./gradlew test",
    "kotlin:lint": "cd kotlin && ./gradlew lint",
    "detox:build": "detox build --configuration android.emu.debug",
    "detox:test": "detox test --configuration android.emu.debug --headless",
    "detox:build:ios": "detox build --configuration ios.sim.debug",
    "detox:test:ios": "detox test --configuration ios.sim.debug --cleanup",
    "test:e2e": "npm run detox:test"
  },
  "detox": {
  "testRunner": {
    "args": {
      "config": "tests/e2e/jest.config.ts"
    }
  },
  "apps": {
    "mobile.android.debug": {
      "type": "android.apk",
      "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
      "testBinaryPath": "android/app/build/outputs/apk/androidTest/debug/app-debug-androidTest.apk",
      "build": "tsx ./scripts/detox-build-android.ts"
    },
    "mobile.ios.debug": {
      "type": "ios.app",
      "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/DetoxApp.app",
      "build": "tsx ./scripts/detox-build-ios.ts"
    }
  },
  "devices": {
    "android.emulator": {
      "type": "android.emulator",
      "device": {
        "avdName": "test"
      }
    },
    "ios.simulator": {
      "type": "ios.simulator",
      "device": {
        "type": "iPhone 15"
      }
    }
  },
  "configurations": {
    "android.emu.debug": {
      "device": "android.emulator",
      "app": "mobile.android.debug"
    },
    "ios.sim.debug": {
      "device": "ios.simulator",
      "app": "mobile.ios.debug"
    }
  }
},
  "dependencies": {
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.3.25",
    "expo": "~54.0.33",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "~18.0.9",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/jest": "~29.5.14",
    "@types/node": "^24.6.1",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^55.0.11",
    "detox": "^20.47.0",
    "eslint": "^9.39.3",
    "eslint-config-expo": "^10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^47.0.1",
    "jiti": "^2.6.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "private": true
}
